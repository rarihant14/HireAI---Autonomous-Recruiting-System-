# ============================================================
# AUTONOMOUS HIRING SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================

# --- GROQ API (Required) ---
# Get your key at: https://console.groq.com/
GROQ_API_KEY=

# --- GROQ MODEL SETTINGS ---
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=4096

# --- GMAIL API (for Component 3: Engagement) ---
# Uses OAuth2 via credentials.json (already in project root).
# On first run a browser window opens for one-time Google account authorisation.
# After that, token.json is saved and reused automatically — no password needed.
#
# SMTP fields below are kept as fallback only if Gmail API send fails.
# Leave SMTP_USER blank if you are using Gmail API exclusively.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- DATABASE ---
# SQLite database path (auto-created)
DATABASE_URL=sqlite:///hiring_system.db

# --- REDIS / CELERY QUEUE (Optional, recommended for background jobs) ---
# When set, heavy endpoints enqueue work instead of blocking the Flask request.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TIMEZONE=UTC
CELERY_BEAT_POLLING_ENABLED=true
CELERY_BEAT_LEARNING_ENABLED=true

# --- FLASK SERVER ---
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# --- SYSTEM SETTINGS ---
# How often (seconds) to poll for new emails
EMAIL_POLL_INTERVAL=120
# How often the scheduled learning check runs
LEARNING_CHECK_INTERVAL=300
# Minimum AI similarity score to flag as AI-generated (0.0–1.0)
AI_SIMILARITY_THRESHOLD=0.80
# Minimum cross-candidate similarity to flag as copied (0.0–1.0)
COPY_SIMILARITY_THRESHOLD=0.60
# Strikes before auto-rejection
MAX_STRIKES=3
# Suspicious reply time in seconds (< this = flag for timing)
SUSPICIOUS_REPLY_SECONDS=120

